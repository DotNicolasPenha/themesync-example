{
  "metadata": {
    "name": "Nordic Blue",
    "author": "Nicolas",
    "version": "1.0.0",
    "license": "MIT"
  },
  "compatible_des": [
    {
      "desktop": "gnome",
      "version_constraint": ">=45.0"
    }
  ],
  "steps": [
    {
      "name": "copy",
      "source": "./themes/Nordic-Blue",
      "target": "~/.themes/Nordic-Blue"
    },
    {
      "name": "copy",
      "source": "./icons/Nordic-Icons",
      "target": "~/.icons/Nordic-Icons"
    },
    {
      "name": "command",
      "target": "gsettings set org.gnome.desktop.interface gtk-theme 'Nordic-Blue'"
    },
    {
      "name": "command",
      "target": "gsettings set org.gnome.desktop.interface icon-theme 'Nordic-Icons'"
    }
  ]
}
